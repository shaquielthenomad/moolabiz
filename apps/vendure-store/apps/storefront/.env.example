# =============================================================================
# Vendure Storefront — Environment Variables
# Copy this file to .env.local and fill in all required values.
# Generate random secrets with: openssl rand -hex 32
# =============================================================================

# ─── Vendure Shop API ─────────────────────────────────────────────────────────

# Server-side URL for the Vendure Shop API (used in server components / RSC)
# Keep this internal (not prefixed NEXT_PUBLIC_) when possible for security.
# Local dev: http://localhost:3000/shop-api
# Production: http://vendure-server:3000/shop-api (internal Docker network)
VENDURE_SHOP_API_URL=http://localhost:3000/shop-api

# Public (client-side) Shop API URL — only set this if you need GraphQL calls
# from the browser. Prefer server-side calls where possible.
# NEXT_PUBLIC_VENDURE_SHOP_API_URL=https://store.moolabiz.shop/shop-api

# ─── Vendure Admin API (for revalidation & admin actions) ────────────────────

# Internal Vendure Admin API URL — used for webhook-triggered revalidation
# Local dev: http://localhost:3000/admin-api
# Production: http://vendure-server:3000/admin-api
VENDURE_ADMIN_API_URL=http://localhost:3000/admin-api

# Static admin auth token for server-side admin API calls (from Vendure admin UI)
# Create a token in Vendure Admin → Settings → API Tokens
VENDURE_ADMIN_AUTH_TOKEN=

# ─── Vendure Channel ─────────────────────────────────────────────────────────

# Default channel token (used when no merchant-specific channel is resolved)
# For MoolaBiz multi-tenant setup: each merchant has their own channel token.
# The storefront resolves the correct token from the hub API based on slug.
VENDURE_CHANNEL_TOKEN=__default_channel__

# Public channel token — only set if the token must be accessible client-side
# NEXT_PUBLIC_VENDURE_CHANNEL_TOKEN=__default_channel__

# ─── Hub API (channel token resolution) ──────────────────────────────────────

# URL of the MoolaBiz hub — used to look up per-merchant Vendure channel tokens
# The storefront calls <HUB_API_URL>/api/channel-token?slug=<slug> at render time.
# Local dev: http://localhost:3001 (or wherever the hub runs)
# Production: https://moolabiz.shop
HUB_API_URL=https://moolabiz.shop

# ─── Site Metadata ────────────────────────────────────────────────────────────

# Public URL for SEO / canonical tags / OpenGraph (no trailing slash)
# Local dev: http://localhost:8080
# Production: https://store.moolabiz.shop
NEXT_PUBLIC_SITE_URL=http://localhost:8080

# Site name shown in browser tab and OpenGraph tags
# NEXT_PUBLIC_SITE_NAME=MoolaBiz Store

# ─── Cache Revalidation ───────────────────────────────────────────────────────

# Secret used to authenticate requests to /api/revalidate
# Vendure webhooks call this endpoint after product/order changes.
# Must be set in both the storefront and in the Vendure webhook configuration.
# Generate: openssl rand -base64 32
REVALIDATION_SECRET=your-secure-random-string-here

# ─── Auth Token Headers/Cookies (advanced — rarely need to change) ────────────

# Cookie name used to store the Vendure auth token on the client
# Default: vendure-auth-token
# VENDURE_AUTH_TOKEN_COOKIE=vendure-auth-token

# Header name Vendure uses to return the auth token after login
# Default: vendure-auth-token
# VENDURE_AUTH_TOKEN_HEADER=vendure-auth-token

# Header name used to pass the channel token to Vendure
# Default: vendure-token
# VENDURE_CHANNEL_TOKEN_HEADER=vendure-token
