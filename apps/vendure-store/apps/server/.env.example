# =============================================================================
# Vendure Server — Environment Variables
# Copy this file to .env and fill in all required values.
# Generate random secrets with: openssl rand -hex 32
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────

# Environment: dev | production
APP_ENV=dev

# HTTP port to listen on (default: 3000)
PORT=3000

# ─── PostgreSQL Database ──────────────────────────────────────────────────────

# Database host (use 'localhost' for local dev, or the Docker service name in production)
DB_HOST=localhost

# Database port (default PostgreSQL port)
DB_PORT=5432

# Database name
DB_NAME=vendure

# Database username
DB_USERNAME=vendure

# Database password
DB_PASSWORD=vendure_secret

# Auto-synchronise schema with entities on startup.
# WARNING: Set to 'false' in production — use migrations instead.
# Set to 'true' only for initial setup or local dev.
DB_SYNCHRONIZE=true

# ─── Authentication ───────────────────────────────────────────────────────────

# Vendure superadmin username (used to seed the initial admin account)
# Must match VENDURE_SUPERADMIN_USERNAME in the hub .env
SUPERADMIN_USERNAME=superadmin

# Vendure superadmin password — choose a strong password in production
# Must match VENDURE_SUPERADMIN_PASSWORD in the hub .env
SUPERADMIN_PASSWORD=

# Secret used to sign session cookies — generate a random 32+ byte string
# Generate: openssl rand -hex 32
COOKIE_SECRET=

# ─── Asset Storage ────────────────────────────────────────────────────────────

# Public URL prefix for product image assets served by Vendure
# In production this should be the CDN/domain where assets are publicly accessible
# Example: https://store.moolabiz.shop/assets/
ASSET_URL_PREFIX=https://store.moolabiz.shop/assets/

# ─── Email ────────────────────────────────────────────────────────────────────

# From address for Vendure order/account emails
# Format: "Display Name" <address@example.com>
EMAIL_FROM_ADDRESS="MoolaBiz" <noreply@moolabiz.shop>

# ─── Storefront ───────────────────────────────────────────────────────────────

# URL of the Next.js storefront — used by Vendure for CORS and email links
# Local dev: http://localhost:8080
# Production: https://store.moolabiz.shop (or the per-merchant subdomain pattern)
STOREFRONT_URL=http://localhost:8080
