{{> header title="Verify your email address" }}

<mj-section background-color="#ffffff" padding="16px 24px 8px 24px">
    <mj-column>
        <mj-text font-size="15px" color="#374151">
            Welcome to MoolaBiz! One quick step to get you started &mdash;
            please verify your email address by clicking the button below.
        </mj-text>
        <mj-text font-size="14px" color="#6b7280" padding-top="4px">
            This link expires in 24 hours. If you did not create an account,
            you can safely ignore this email.
        </mj-text>
    </mj-column>
</mj-section>

<mj-section background-color="#ffffff" padding="8px 24px 24px 24px">
    <mj-column>
        <mj-button font-family="Arial, sans-serif"
                   background-color="#059669"
                   color="#ffffff"
                   font-size="15px"
                   font-weight="bold"
                   border-radius="6px"
                   padding="14px 28px"
                   href="{{ verifyEmailAddressUrl }}?token={{ verificationToken }}">
            Verify my email
        </mj-button>
        <mj-text font-size="12px" color="#9ca3af" padding-top="12px">
            Button not working? Copy and paste this link into your browser:<br />
            <a href="{{ verifyEmailAddressUrl }}?token={{ verificationToken }}" style="color:#059669;word-break:break-all;">
                {{ verifyEmailAddressUrl }}?token={{ verificationToken }}
            </a>
        </mj-text>
    </mj-column>
</mj-section>

{{> footer }}
