{{> header title="Order Confirmation" }}

<mj-raw>
    <style type="text/css">
    .callout-section {
        background-color: #059669;
    }
    .callout-label > div {
        text-align: center !important;
        color: #d1fae5 !important;
        font-size: 11px !important;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 0;
    }
    .callout-value > div {
        text-align: center !important;
        color: #ffffff !important;
        font-size: 15px !important;
        font-weight: bold;
        padding: 0;
    }
    ul.address {
        list-style-type: none;
        padding: 0;
        margin: 0;
    }
    ul.address li {
        padding: 2px 0;
        color: #374151;
        font-size: 14px;
    }
    tr.order-row td {
        border-bottom: 1px solid #f3f4f6;
        padding: 10px 6px;
        vertical-align: middle;
        font-size: 14px;
        color: #374151;
    }
    tr.total-row td {
        font-weight: bold;
        font-size: 15px;
        color: #111827;
        border-top: 2px solid #e5e7eb;
        border-bottom: none;
    }
    .cod-notice > div {
        background-color: #ecfdf5 !important;
        border-left: 4px solid #059669 !important;
        padding: 12px 16px !important;
        font-size: 14px !important;
        color: #065f46 !important;
        border-radius: 4px;
    }
    </style>
</mj-raw>

<!-- Greeting -->
<mj-section background-color="#ffffff" padding="8px 24px 0 24px">
    <mj-column>
        <mj-text font-size="16px" color="#111827">
            Hi <strong>{{#if order.customer.firstName}}{{ order.customer.firstName }}{{else}}there{{/if}}</strong>,
        </mj-text>
        <mj-text font-size="15px" color="#374151" padding-top="4px">
            Thanks for your order! We have received it and it is being processed.
            You will get another email once your order ships.
        </mj-text>
    </mj-column>
</mj-section>

<!-- Order summary callout bar -->
<mj-section css-class="callout-section" padding="14px 24px">
    <mj-column>
        <mj-text css-class="callout-label">Order Number</mj-text>
        <mj-text css-class="callout-value">{{ order.code }}</mj-text>
    </mj-column>
    <mj-column>
        <mj-text css-class="callout-label">Order Date</mj-text>
        <mj-text css-class="callout-value">{{ formatDate order.orderPlacedAt }}</mj-text>
    </mj-column>
    <mj-column>
        <mj-text css-class="callout-label">Total</mj-text>
        <mj-text css-class="callout-value">{{ formatMoney order.totalWithTax order.currencyCode 'en' }}</mj-text>
    </mj-column>
</mj-section>

<!-- Shipping address -->
<mj-section background-color="#ffffff" padding="16px 24px 8px 24px">
    <mj-column>
        <mj-text font-size="14px" font-weight="bold" color="#111827" padding-bottom="4px">
            Shipping To
        </mj-text>
        <mj-text font-size="14px" color="#374151">
            {{#with order.shippingAddress }}
                <ul class="address">
                    {{#if fullName}}<li><strong>{{ fullName }}</strong></li>{{/if}}
                    {{#if company}}<li>{{ company }}</li>{{/if}}
                    {{#if streetLine1}}<li>{{ streetLine1 }}</li>{{/if}}
                    {{#if streetLine2}}<li>{{ streetLine2 }}</li>{{/if}}
                    {{#if city}}<li>{{ city }}{{#if province}}, {{ province }}{{/if}}</li>{{/if}}
                    {{#if postalCode}}<li>{{ postalCode }}</li>{{/if}}
                    {{#if country}}<li>{{ country }}</li>{{/if}}
                    {{#if phoneNumber}}<li>&#128222; {{ phoneNumber }}</li>{{/if}}
                </ul>
            {{/with}}
        </mj-text>
    </mj-column>
</mj-section>

<!-- Order items table -->
<mj-section background-color="#ffffff" padding="8px 24px 16px 24px">
    <mj-column>
        <mj-text font-size="14px" font-weight="bold" color="#111827" padding-bottom="4px">
            Order Items
        </mj-text>
        <mj-table cellpadding="6px">
            {{#each order.lines }}
                <tr class="order-row">
                    <td style="width:56px;">
                        <img alt="{{ productVariant.name }}"
                             style="width:50px;height:50px;object-fit:cover;border-radius:4px;display:block;"
                             src="{{ featuredAsset.preview }}?w=50&h=50" />
                    </td>
                    <td>{{ productVariant.name }}</td>
                    <td style="white-space:nowrap;color:#6b7280;">x{{ quantity }}</td>
                    <td style="white-space:nowrap;text-align:right;">{{ formatMoney discountedLinePriceWithTax ../order.currencyCode 'en' }}</td>
                </tr>
            {{/each}}
            {{#each order.discounts }}
                <tr class="order-row">
                    <td colspan="3" style="color:#059669;">{{ description }}</td>
                    <td style="white-space:nowrap;text-align:right;color:#059669;">-{{ formatMoney amount ../order.currencyCode 'en' }}</td>
                </tr>
            {{/each}}
            <tr class="order-row">
                <td colspan="3" style="color:#6b7280;">Subtotal</td>
                <td style="white-space:nowrap;text-align:right;">{{ formatMoney order.subTotalWithTax order.currencyCode 'en' }}</td>
            </tr>
            {{#each order.shippingLines }}
            <tr class="order-row">
                <td colspan="3" style="color:#6b7280;">Shipping ({{ shippingMethod.name }})</td>
                <td style="white-space:nowrap;text-align:right;">{{ formatMoney priceWithTax ../order.currencyCode 'en' }}</td>
            </tr>
            {{/each}}
            <tr class="order-row total-row">
                <td colspan="3">Total</td>
                <td style="white-space:nowrap;text-align:right;">{{ formatMoney order.totalWithTax order.currencyCode 'en' }}</td>
            </tr>
        </mj-table>
    </mj-column>
</mj-section>

<!-- COD notice -->
<mj-section background-color="#ffffff" padding="0 24px 16px 24px">
    <mj-column>
        <mj-text css-class="cod-notice" font-size="14px">
            <strong>Payment:</strong> This order uses Cash on Delivery (COD).
            Please have the exact amount ready when your order arrives.
            If you have any questions about payment, reply to this email.
        </mj-text>
    </mj-column>
</mj-section>

{{> footer }}
