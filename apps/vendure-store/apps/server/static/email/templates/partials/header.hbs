<mjml>
    <mj-head>
        <mj-title>{{ title }}</mj-title>
        <mj-preview>{{ title }}</mj-preview>
        <mj-attributes>
            <mj-all font-family="Arial, sans-serif" />
            <mj-text font-size="15px" line-height="1.6" color="#374151" />
        </mj-attributes>
        <mj-style inline="inline">
            a { color: #059669; }
        </mj-style>
    </mj-head>

    <mj-body background-color="#f3f4f6">

        <!-- Top brand bar -->
        <mj-section background-color="#059669" padding="20px 24px">
            <mj-column>
                <mj-text align="center" font-size="22px" font-weight="bold" color="#ffffff" letter-spacing="1px">
                    MoolaBiz
                </mj-text>
                <mj-text align="center" font-size="12px" color="#d1fae5" padding-top="2px">
                    Your local online shop
                </mj-text>
            </mj-column>
        </mj-section>

        <!-- White card start -->
        <mj-section background-color="#ffffff" padding="0">
            <mj-column padding="24px 24px 0 24px">
                <mj-text font-size="18px" font-weight="bold" color="#111827">
                    {{ title }}
                </mj-text>
            </mj-column>
        </mj-section>
