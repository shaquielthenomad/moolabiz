{{> header title="Reset your password" }}

<mj-section background-color="#ffffff" padding="16px 24px 8px 24px">
    <mj-column>
        <mj-text font-size="15px" color="#374151">
            We received a request to reset the password for your MoolaBiz account.
            Click the button below to choose a new password.
        </mj-text>
        <mj-text font-size="14px" color="#6b7280" padding-top="4px">
            This link expires in 1 hour. If you did not request a password reset,
            you can safely ignore this email &mdash; your password will not change.
        </mj-text>
    </mj-column>
</mj-section>

<mj-section background-color="#ffffff" padding="8px 24px 8px 24px">
    <mj-column>
        <mj-button font-family="Arial, sans-serif"
                   background-color="#059669"
                   color="#ffffff"
                   font-size="15px"
                   font-weight="bold"
                   border-radius="6px"
                   padding="14px 28px"
                   href="{{ passwordResetUrl }}?token={{ passwordResetToken }}">
            Reset my password
        </mj-button>
        <mj-text font-size="12px" color="#9ca3af" padding-top="12px">
            Button not working? Copy and paste this link into your browser:<br />
            <a href="{{ passwordResetUrl }}?token={{ passwordResetToken }}" style="color:#059669;word-break:break-all;">
                {{ passwordResetUrl }}?token={{ passwordResetToken }}
            </a>
        </mj-text>
    </mj-column>
</mj-section>

<mj-section background-color="#ffffff" padding="0 24px 24px 24px">
    <mj-column>
        <mj-text font-size="13px" color="#6b7280"
                 container-background-color="#f9fafb"
                 padding="12px 16px"
                 border-radius="4px">
            For your security, never share this link with anyone.
            MoolaBiz staff will never ask for your password.
        </mj-text>
    </mj-column>
</mj-section>

{{> footer }}
